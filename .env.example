# Puerto del servidor (Railway asigna PORT automáticamente)
PORT=3001

# MongoDB Atlas — crea tu cluster en https://cloud.mongodb.com
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/repuestos?appName=Cluster0

# Anthropic Claude API — obtén tu key en https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-api03-XXXXXXXX

# Margen de ganancia por defecto (0.28 = 28%)
MARGIN_DEFAULT=0.28

# Tiempo de espera para proveedores en ms (600000 = 10 min)
SUPPLIER_TIMEOUT_MS=600000

# Número WhatsApp del proveedor de prueba (formato: 569XXXXXXXX sin + ni @c.us)
TEST_SUPPLIER_NUMBER=56912345678

# URL pública del servidor (se usa en links que el bot envía)
LANDING_URL=https://tu-app.railway.app

# Railway inyecta esto automáticamente si usas nixpacks con Puppeteer
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium-browser
